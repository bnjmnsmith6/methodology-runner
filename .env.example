# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# AI API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# AI Adapter Configuration
# Set USE_REAL_PBCA=true to use real OpenAI API for PBCA research
# Set USE_REAL_PBCA=false (or omit) to use mock adapter
USE_REAL_PBCA=false
OPENAI_MODEL=gpt-4o

# Code Puppy (Claude Code CLI) - LOCAL ONLY
# Set USE_REAL_CODEPUPPY=true to use real Claude Code CLI for builds
# Set USE_REAL_CODEPUPPY=false to use mock adapter
# NOTE: Claude Code CLI requires local installation and cannot run in containers.
#       On Railway/production, this MUST be false. Builds will use mock adapter.
#       For real builds, run the worker locally with Claude Code CLI installed.
USE_REAL_CODEPUPPY=false

# Server Configuration
PORT=3000

# Worker Configuration
WORKER_LEASE_DURATION_MS=300000
WORKER_POLL_INTERVAL_MS=2000
WORKER_RECONCILE_INTERVAL_MS=60000

# Environment
NODE_ENV=development
